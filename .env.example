# JWT (üretimde mutlaka uzun rastgele dize)
JWT_SECRET=uzun-rastgele-bir-dize

# Form linkleri ve QR kodunun içindeki URL (sonda / olmasın).
# Örnek: http://SUNUCU_IP veya https://form.sirketiniz.com
# HTTPS kullanıyorsanız şema https olmalı (docker-compose.https.yml + deploy/ssl).
PUBLIC_FORM_BASE_URL=http://SUNUCU_IP

# "Link kopyala" için dış adres (Vite build). Boş = tarayıcı adresi.
# VITE_PUBLIC_FORM_BASE_URL=https://form.ornek.com

# Docker web konteynerinin HOST'taki portu (içeride hep 80).
# Sunucuda sistem nginx zaten 80 kullanıyorsa çakışır → 403 ve nginx/1.18 görürsünüz.
# O zaman: WEB_PORT=8080 yapın; deploy/host-reverse-proxy.example.conf ile 80→8080 vekil kurun.
WEB_PORT=80

# Public form submit JSON boyut limiti (dosya/base64 alanlari icin)
# REQUEST_BODY_LIMIT=20mb

# HTTPS için ikinci compose ile birlikte (443 dışarı açılır):
#   docker compose -f docker-compose.yml -f docker-compose.https.yml up -d --build
# HTTPS_PORT=443
# SSL_CERT_DIR=./deploy/ssl

# İnternete yalnızca /f/... için genelde ayrı proxy / firewall kullanılır.

# Microsoft Teams Incoming Webhook URL (bildirim için)
# Örn: https://outlook.office.com/webhook/...
TEAMS_WEBHOOK_URL=

# E-posta (üretimde gerçek SMTP; MailHog sadece test)
# MAIL_HOST=smtp.ornek.com
# MAIL_PORT=587
# MAIL_FROM=noreply@ornek.com
