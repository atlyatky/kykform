# JWT (üretimde mutlaka uzun rastgele dize)
JWT_SECRET=uzun-rastgele-bir-dize

# Form linkleri ve QR kodunun içindeki URL (sonda / olmasın).
# İç ağ (VPN / ofis): http://SUNUCU_IP
# İnternetten erişim: gerçek alan adı veya genel IP (örn. https://form.sirketiniz.com)
# Not: 172.16.x.x / 10.x.x.x / 192.168.x.x adresleri internette yönlendirilmez; dışarıdan
# açılması için yönlendirici NAT (port 80/443), bulut VPS genel IP veya DNS gerekir.
PUBLIC_FORM_BASE_URL=https://form.ornek.com

# Yönetim panelinde "Link kopyala" için dış adres (Vite build). Boş = tarayıcı adresi.
# Örnek: https://form.ornek.com
# VITE_PUBLIC_FORM_BASE_URL=https://form.ornek.com

# --- İki katmanlı erişim (önerilen) ---
# Dış dünya: web-public servisi (sadece form doldurma /f/... ve /api/public/)
WEB_PORT=80
# Yönetim (liste, düzenleme): yalnızca sunucuda veya VPN ile — http://SUNUCU_IP:8080
ADMIN_WEB_PORT=8080
# Yönetim API (auth, formlar) internetten çağrılamasın diye izin verilen IPv4 aralıkları (virgülle).
# Örnek: ofis + Docker köprü + özel ağlar. Boş bırakırsanız API IP kısıtı uygulanmaz (sadece geliştirme).
# ADMIN_IP_ALLOWLIST=127.0.0.1,172.16.0.0/12,10.0.0.0/8,192.168.0.0/16

# E-posta (üretimde gerçek SMTP; MailHog sadece test)
# MAIL_HOST=smtp.ornek.com
# MAIL_PORT=587
# MAIL_FROM=noreply@ornek.com
