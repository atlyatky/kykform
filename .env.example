# JWT (üretimde mutlaka uzun rastgele dize)
JWT_SECRET=uzun-rastgele-bir-dize

# Form linkleri ve QR için kök adres (sonda / olmasın)
# Örnek iç ağ: http://172.16.26.27
# Örnek dış domain: https://form.sirket.com
PUBLIC_FORM_BASE_URL=http://172.16.26.27

# Web arayüzü dış portu (VPS: genelde 80 veya 8080)
WEB_PORT=80

# E-posta (üretimde gerçek SMTP; MailHog sadece test)
# MAIL_HOST=smtp.ornek.com
# MAIL_PORT=587
# MAIL_FROM=noreply@ornek.com
