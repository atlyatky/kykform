generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AdminRole {
  ADMIN
  USER
}

model Admin {
  id           String    @id @default(cuid())
  email        String    @unique
  role         AdminRole @default(ADMIN)
  passwordHash String
  totpEnabled  Boolean   @default(false)
  /// base32 (Google Authenticator / TOTP). Enabled ise dolu olmalı.
  totpSecret   String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model FirewallConfig {
  id        String   @id
  rulesJson String   @default("{}")
  updatedAt DateTime @updatedAt
}

enum FormPeriodUnit {
  NONE
  DAY
  MONTH
  YEAR
}

model Form {
  id                   String         @id @default(cuid())
  title                String
  description          String?
  slug                 String         @unique
  published            Boolean        @default(false)
  slaHours             Int?
  notifyEmails         String         @default("[]")
  revision             Int            @default(1)
  
  periodUnit           FormPeriodUnit @default(NONE)
  periodValue          Int            @default(1)
  expectedSubmissions  Int            @default(1)
  
  lastPeriodicNotifyAt DateTime?
  invalidAlertEnabled  Boolean        @default(false)
  /// Örn. forklift no — bu sorunun cevabına göre kota sayılır (boş = tüm forma toplam kota)
  quotaQuestionId      String?
  /// Beklenen varlık listesi JSON: ["FL-01","FL-02"]. Boşsa yalnızca gelen cevaplara göre kontrol
  quotaEntityListJson  String         @default("[]")
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  questions            Question[]
  submissions          Submission[]
  sessions             FormSession[]
  flowRules            FormFlowRule[]
}

enum QuestionType {
  AGREEMENT
  PAGE_BREAK
  FILE
  GRID
  TEXT
  TEXTAREA
  SINGLE_CHOICE
  MULTI_CHOICE
  NUMBER
  DATE
}

model Question {
  id           String       @id @default(cuid())
  formId       String
  form         Form         @relation(fields: [formId], references: [id], onDelete: Cascade)
  orderIndex   Int
  type         QuestionType
  title        String
  description  String?
  required     Boolean      @default(false)
  optionsJson  String       @default("[]")
  rowsJson     String?      @default("[]")
  showWhenJson String?
  createdAt    DateTime     @default(now())
}

model Submission {
  id          String   @id @default(cuid())
  formId      String
  form        Form     @relation(fields: [formId], references: [id], onDelete: Cascade)
  answersJson String
  score       Int?     @default(0)
  createdAt   DateTime @default(now())
}

model FormSession {
  id            String    @id @default(cuid())
  formId        String
  form          Form      @relation(fields: [formId], references: [id], onDelete: Cascade)
  sessionKey    String
  openedAt      DateTime  @default(now())
  submittedAt   DateTime?
  slaNotifiedAt DateTime?

  @@unique([formId, sessionKey])
}

model FormFlowRule {
  id            String   @id @default(cuid())
  formId        String
  form          Form     @relation(fields: [formId], references: [id], onDelete: Cascade)
  name          String
  enabled       Boolean  @default(true)
  /// ON_SCHEDULE | ON_SUBMIT (MVP: ON_SCHEDULE destekli)
  trigger       String   @default("ON_SCHEDULE")
  /// JSON: { kind, questionId, periodUnit, periodValue, minCount, entities[] }
  conditionJson String
  /// JSON: { kind: "SEND_EMAIL", emails[], subject? }
  actionJson    String
  lastFiredAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
